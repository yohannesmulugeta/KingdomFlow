{
  "name": "User",
  "type": "object",
  "properties": {
    "church_role": {
      "type": "string",
      "enum": [
        "church_admin",
        "pastor",
        "treasurer",
        "department_leader",
        "auditor"
      ],
      "default": "department_leader"
    },
    "branch_id": {
      "type": "string",
      "description": "Assigned branch for branch-specific users"
    },
    "department_id": {
      "type": "string",
      "description": "Assigned department"
    },
    "access_scope": {
      "type": "string",
      "enum": [
        "all_branches",
        "assigned_branch"
      ],
      "default": "assigned_branch"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "suspended",
        "pending"
      ],
      "default": "active"
    },
    "phone": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  }
}